{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "baby-spike-tauri",
  "version": "0.0.0",
  "identifier": "com.baby.spike.tauri",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:renderer",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Baby spike · Tauri",
        "width": 1280,
        "height": 800,
        "backgroundColor": "#0b0d12"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
