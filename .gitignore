# Secrets — never commit
.env

# Python
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/

# Runtime data
baby.db
baby.db-wal
baby.db-shm
setup.json
backups/
logs/

# Models / large artifacts
models/*.onnx
models/*.bin
assets/baby_ready.wav

# Knowledge graph (regenerable via /graphify)
graphify-out/

# Local tool config
.claude/

# Owner voice profile - biometric, never publish
models/owner_voice.json

# Graphify wrapper junk (not a node project) — root-anchored so ui/app/ is unaffected
/node_modules/
/package.json
/package-lock.json

# v3 frontend (ui/app) — build-on-setup: commit sources + lockfile, ignore installs/builds
ui/app/node_modules/
ui/app/dist/

# v4 native shell (ui/shell) — commit sources + Cargo.lock + icons, ignore installs/builds
ui/shell/**/node_modules/
ui/shell/**/target/
ui/shell/**/dist/
ui/shell/**/gen/

# v6 installer: staged backend payload (built by scripts/stage_payload.ps1, bundled as a resource)
ui/shell/src-tauri/payload/
